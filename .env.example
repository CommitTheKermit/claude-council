# Claude 인증
# 주의: ANTHROPIC_API_KEY 를 설정하면 Agent SDK 가 그 키로 "종량 과금"된다.
# Max/Pro 구독으로 추가 과금 없이 쓰려면 이 키를 설정하지 말 것(주석/공란 유지).
# 대신 로컬에서 한 번 `claude /login` 으로 구독 OAuth 세션을 만들어 두면 됨
# (CI 등 비대화형 환경은 `claude setup-token` 으로 CLAUDE_CODE_OAUTH_TOKEN 발급).
# ANTHROPIC_API_KEY=

# Discord 봇 토큰
DISCORD_TOKEN=
# 질문을 포워딩하고 투표를 받을 채널 ID
DISCORD_CHANNEL_ID=

# 투표 규칙 (선택, 미설정 시 기본값 사용)
# 타임아웃(초), 기본 180 (3분)
VOTE_TIMEOUT_SECONDS=180
# 정족수 비율(0~1), 기본 0.5 (과반)
VOTE_QUORUM_RATIO=0.5
# 호스트(최종 결정권자) Discord 사용자 ID
HOST_USER_ID=
